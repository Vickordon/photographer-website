# Production Environment Variables
# Copy this file to .env and update with your values

# Generate secret key: mix phx.gen.secret
SECRET_KEY_BASE=change_this_in_production

# Database (configured in docker-compose.yml)
DATABASE_URL=postgresql://photographer:photographer_password@db:5432/photographer_prod

# Server
PORT=4000
POOL_SIZE=10

# Email (SMTP) - Optional for local dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@photographer.com

# Application
APP_URL=http://localhost:4000
ENV=production

# AWS S3 (optional for image storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET=your-bucket-name
